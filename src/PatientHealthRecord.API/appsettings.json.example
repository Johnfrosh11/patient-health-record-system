{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=PatientHealthRecordDB;Username=postgres;Password=your_password_here"
  },
  "JwtSettings": {
    "SecretKey": "your-very-secure-secret-key-must-be-at-least-32-characters-long-for-hs256",
    "Issuer": "PatientHealthRecordAPI",
    "Audience": "PatientHealthRecordClient",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "CorsOrigins": [
    "http://localhost:3000",
    "http://localhost:5173"
  ],
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1,
    "QueueLimit": 10
  },
  "GlobalSettings": {
    "EmailSettings": {
      "ApiKey": "",
      "FromEmail": "noreply@yourdomain.com",
      "FromName": "Patient Health Record System"
    }
  }
}
